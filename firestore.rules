rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Friends subcollection
      match /friends/{friendId} {
        allow read, write: if request.auth.uid == userId;
      }

      // Notifications subcollection
      match /notifications/{notifId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth != null; // 다른 사용자가 알림 생성 가능
        allow update: if request.auth.uid == userId; // 읽음 처리
        allow delete: if request.auth.uid == userId;
      }
    }

    // ─── Albums ───
    match /albums/{albumId} {
      // 앨범 읽기: 멤버이거나 공개 앨범
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        resource.data.visibility == 'public' ||
        (resource.data.visibility == 'friends' && isFriend(request.auth.uid, resource.data.ownerId))
      );

      // 앨범 생성: 인증된 사용자
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.ownerId;

      // 앨범 수정: 멤버만
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.memberIds;

      // 앨범 삭제: 소유자만
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;

      // Pages subcollection
      match /pages/{pageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/albums/$(albumId)).data.memberIds;
        allow write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/albums/$(albumId)).data.memberIds;
      }
    }

    // ─── Templates ───
    match /templates/{templateId} {
      allow read: if request.auth != null && (
        resource.data.isPublic == true ||
        request.auth.uid == resource.data.createdBy
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;
    }

    // ─── Helper Functions ───
    function isFriend(userId, targetUserId) {
      return exists(/databases/$(database)/documents/users/$(targetUserId)/friends/$(userId));
    }
  }
}
